# Copy this to .env and fill in your values
# Never commit .env to git

# PostgreSQL connection string (get from Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Random secret for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Server port (Render sets this automatically to 10000)
PORT=3001

# Google Gemini API key — get free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Allowed frontend origin for CORS (set to your Vercel URL in production)
# CORS_ORIGIN=https://your-app.vercel.app
